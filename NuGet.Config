<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <!-- 仅合并 nuget.org，避免本机全局 NuGet 配置里无效的本地源（如指向不存在的 PluginAbstractions\nupkg）导致还原失败。契约库见独立仓库与 docs/repositories.md；Host 通过 ProjectReference 联调本地 clone。 -->
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
  </packageSources>
</configuration>
