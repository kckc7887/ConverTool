{
  "strings": {
    "plugin/imagemagick.image.transcoder/title": "ImageMagick 图像转换",
    "plugin/imagemagick.image.transcoder/description": "使用 ImageMagick（magick 命令行）进行常见图片格式互转；可选按目标文件大小进行有损压缩（见下方选项）。",

    "plugin/imagemagick.image.transcoder/target/avif": "AVIF（高压缩率）",
    "plugin/imagemagick.image.transcoder/target/bmp": "BMP（无压缩）",
    "plugin/imagemagick.image.transcoder/target/gif": "GIF（兼容性好）",
    "plugin/imagemagick.image.transcoder/target/ico": "ICO（图标）",
    "plugin/imagemagick.image.transcoder/target/jpeg": "JPEG（体积更小）",
    "plugin/imagemagick.image.transcoder/target/jpg": "JPG（体积更小）",
    "plugin/imagemagick.image.transcoder/target/png": "PNG（无损 + 透明）",
    "plugin/imagemagick.image.transcoder/target/tif": "TIF（与 TIFF 相同）",
    "plugin/imagemagick.image.transcoder/target/tiff": "TIFF（印刷 / 存档）",
    "plugin/imagemagick.image.transcoder/target/webp": "WebP（网页省空间）",

    "plugin/imagemagick.image.transcoder/section/targetSize": "按目标大小压缩",

    "plugin/imagemagick.image.transcoder/field/enableTargetSizeCompression/label": "启用按目标大小压缩",
    "plugin/imagemagick.image.transcoder/field/enableTargetSizeCompression/help": "开启后，仅对 JPG / JPEG / WebP / AVIF 等有损格式尝试把输出体积控制在设定区间内（通过调节质量等）。启用时，PNG、BMP、GIF、TIFF 等无损目标会从列表中隐藏，以免误选。",

    "plugin/imagemagick.image.transcoder/field/retainTargetSizeCompressionSettings/label": "保留压缩设置",
    "plugin/imagemagick.image.transcoder/field/retainTargetSizeCompressionSettings/help": "勾选后：在相同目标格式与相同目标大小区间下，会复用上次搜索得到的压缩质量以加速转换。\n\n未勾选本项时，写入用户设置文件时会把「启用按目标大小压缩」存为关闭（下次启动默认不勾选），以便不长期保持开启；当前会话内仍可照常使用（详见 Host 的 `fieldPersistOverrides`）。",

    "plugin/imagemagick.image.transcoder/field/targetSizeUnit/label": "大小单位",
    "plugin/imagemagick.image.transcoder/field/targetSizeUnit/help": "下列「最小 / 最大目标大小」使用该单位；插件内部会统一换算为 KB 参与计算。",

    "plugin/imagemagick.image.transcoder/field/targetSizeUnit/opt/KB": "KB",
    "plugin/imagemagick.image.transcoder/field/targetSizeUnit/opt/MB": "MB",

    "plugin/imagemagick.image.transcoder/field/targetSizeMaxKb/label": "最大目标大小",
    "plugin/imagemagick.image.transcoder/field/targetSizeMaxKb/help": "期望的输出文件体积上限（按所选单位）。与「最小」共同构成区间；大于 0 时参与有损压缩搜索。",

    "plugin/imagemagick.image.transcoder/field/targetSizeMinKb/label": "最小目标大小",
    "plugin/imagemagick.image.transcoder/field/targetSizeMinKb/help": "期望的输出文件体积下限（按所选单位）。可与「最大」一起限定区间；均为 0 时表示不启用区间限制（仍取决于是否勾选「启用按目标大小压缩」）。"
  }
}
