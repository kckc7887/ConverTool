<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:Host.ViewModels"
        xmlns:input="clr-namespace:Avalonia.Input;assembly=Avalonia.Base"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="Host.MainWindow"
        x:Name="RootWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="avares://Host/Assets/convertool-icon.ico"
        Title="{Binding HostTitle}">
    <DockPanel Margin="{DynamicResource PagePadding}" LastChildFill="True" PointerPressed="OnRootPointerPressed">
        <!-- 顶部栏：标题 + 操作区 -->
        <Border DockPanel.Dock="Top" Padding="0,0,0,20" Margin="0,0,0,8"
                BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                BorderThickness="0,0,0,1">
            <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto">
                <TextBlock FontSize="22" FontWeight="Bold" VerticalAlignment="Center"
                           Text="{Binding HostTitle}"
                           Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}" />
                <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center" Grid.Column="1">
                    <TextBlock VerticalAlignment="Center" Opacity="0.8" Text="{Binding LanguageLabel}" />
                    <ComboBox Width="160" IsEnabled="{Binding CanEdit}"
                              ItemsSource="{Binding Languages}" SelectedItem="{Binding SelectedLanguage}" />
                    <Button MinWidth="120" Classes="secondary"
                            Content="{Binding AddPluginLabel}"
                            Command="{Binding AddPluginCommand}"
                            IsEnabled="{Binding CanEdit}" />
                    <Button MinWidth="140" Classes="secondary"
                            Content="{Binding ManagePluginsLabel}"
                            Click="OnOpenPluginManager"
                            IsEnabled="{Binding CanEdit}" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid ColumnDefinitions="*,1,420" ColumnSpacing="0" RowDefinitions="*"
              MinWidth="720">
            <!-- 左侧：输入、配置、输出（可滚动） -->
            <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Hidden" HorizontalScrollBarVisibility="Disabled"
                           Padding="0" Margin="0,0,12,0">
                <StackPanel Spacing="20" HorizontalAlignment="Stretch">
                    <!-- 输入 -->
                    <StackPanel Spacing="10">
                        <TextBlock FontWeight="SemiBold" FontSize="16" Text="{Binding InputHeader}"
                                   Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}" />
                        <Border Classes="card" IsEnabled="{Binding CanEdit}" HorizontalAlignment="Stretch">
                            <StackPanel Spacing="12">
                                <StackPanel HorizontalAlignment="Right" Orientation="Horizontal" Spacing="10">
                                    <Button MinWidth="100" Content="{Binding InputBrowseLabel}"
                                            Command="{Binding BrowseInputCommand}" />
                                    <Button MinWidth="100" Classes="secondary"
                                            Content="{Binding InputClearAllLabel}"
                                            Command="{Binding ClearAllInputCommand}"
                                            IsEnabled="{Binding HasInputFiles}" />
                                </StackPanel>
                                <Border MinHeight="120"
                                        BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                                        BorderThickness="1"
                                        CornerRadius="6"
                                        Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"
                                        input:DragDrop.AllowDrop="True"
                                        input:DragDrop.DragOver="OnInputDragOver"
                                        input:DragDrop.Drop="OnInputDrop">
                                    <Grid MinHeight="104">
                                        <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center"
                                                   TextAlignment="Center"
                                                   Text="{Binding InputPlaceholder}"
                                                   TextWrapping="Wrap"
                                                   Margin="16"
                                                   Opacity="0.65"
                                                   IsVisible="{Binding HasNoInputFiles}"
                                                   IsHitTestVisible="False" />
                                        <ScrollViewer MaxHeight="220" IsVisible="{Binding HasInputFiles}"
                                                      VerticalScrollBarVisibility="Auto"
                                                      HorizontalScrollBarVisibility="Disabled">
                                            <ItemsControl ItemsSource="{Binding InputFiles}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate x:DataType="vm:InputFileItemVm">
                                                        <Grid Margin="0,0,0,8"
                                                              ColumnDefinitions="Auto,*,Auto"
                                                              ColumnSpacing="10">
                                                            <Viewbox Width="22" Height="22" VerticalAlignment="Center">
                                                                <Path Fill="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                                                                      Stretch="Uniform"
                                                                      Data="M6,2h7l5,5v13a2,2 0 0 1-2,2H6a2,2 0 0 1-2-2V4A2,2 0 0 1 6,2Z M13,2v6h6" />
                                                            </Viewbox>
                                                            <TextBlock Grid.Column="1" VerticalAlignment="Center"
                                                                       Text="{Binding FileName}"
                                                                       TextTrimming="CharacterEllipsis"
                                                                       ToolTip.Tip="{Binding FullPath}" />
                                                            <Button Grid.Column="2" Classes="secondary"
                                                                    MinWidth="56" Padding="8,4"
                                                                    Content="{Binding #RootWindow.DataContext.InputRemoveLabel}"
                                                                    Command="{Binding RemoveCommand}" />
                                                        </Grid>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </ScrollViewer>
                                    </Grid>
                                </Border>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <!-- 配置 -->
                    <StackPanel Spacing="10">
                        <TextBlock FontWeight="SemiBold" FontSize="16" Text="{Binding ConfigHeader}"
                                   Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}" />
                        <Border Classes="card" IsEnabled="{Binding CanEdit}" HorizontalAlignment="Stretch">
                            <StackPanel Spacing="14">
                                <TextBlock Text="{Binding ConfigPlaceholder}" TextWrapping="Wrap" Opacity="0.9" />
                                <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center"
                                            IsVisible="{Binding HasActivePlugin}">
                                    <TextBlock VerticalAlignment="Center" Text="{Binding TargetFormatLabel}" />
                                    <!-- Flyout+ListBox：折叠态显示 displayNameKey 文案；下拉项同行左文案、右 id。 -->
                                    <Button x:Name="TargetFormatChooserButton"
                                            MinWidth="200"
                                            HorizontalAlignment="Left"
                                            HorizontalContentAlignment="Stretch"
                                            Padding="10,6"
                                            Classes="secondary"
                                            IsEnabled="{Binding HasTargetFormats}">
                                        <Button.Flyout>
                                            <Flyout Placement="BottomEdgeAlignedLeft">
                                                <ListBox Width="280"
                                                         MaxHeight="320"
                                                         ItemsSource="{Binding TargetFormats}"
                                                         SelectedItem="{Binding SelectedTargetFormat, Mode=TwoWay}"
                                                         KeyDown="OnTargetFormatFlyoutListKeyDown"
                                                         PointerReleased="OnTargetFormatFlyoutListPointerReleased">
                                                    <ListBox.ItemTemplate>
                                                        <DataTemplate x:DataType="vm:TargetFormatVm">
                                                            <Grid Margin="0,4"
                                                                  ColumnDefinitions="*,Auto"
                                                                  ColumnSpacing="8"
                                                                  VerticalAlignment="Center">
                                                                <TextBlock Grid.Column="0"
                                                                           VerticalAlignment="Center"
                                                                           Text="{Binding Text}"
                                                                           TextWrapping="Wrap" />
                                                                <TextBlock Grid.Column="1"
                                                                           VerticalAlignment="Center"
                                                                           Opacity="0.65"
                                                                           FontSize="11"
                                                                           Text="{Binding Id}" />
                                                            </Grid>
                                                        </DataTemplate>
                                                    </ListBox.ItemTemplate>
                                                </ListBox>
                                            </Flyout>
                                        </Button.Flyout>
                                        <Grid ColumnDefinitions="*,Auto">
                                            <TextBlock VerticalAlignment="Center"
                                                       HorizontalAlignment="Left"
                                                       Text="{Binding SelectedTargetFormatDisplayText}"
                                                       TextTrimming="CharacterEllipsis" />
                                            <TextBlock Grid.Column="1"
                                                       VerticalAlignment="Center"
                                                       Margin="8,0,0,0"
                                                       FontSize="12"
                                                       Opacity="0.75"
                                                       Text="▾" />
                                        </Grid>
                                    </Button>
                                </StackPanel>
                                <ItemsControl ItemsSource="{Binding ConfigFields}" IsVisible="{Binding HasActivePlugin}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="vm:ConfigFieldVm">
                                            <StackPanel Spacing="8" Margin="0,10,0,0" IsVisible="{Binding IsVisible}">
                                                <TextBlock Classes="section-title" Text="{Binding Label}" />
                                                <ContentControl Content="{Binding}">
                                                    <ContentControl.DataTemplates>
                                                        <DataTemplate x:DataType="vm:TextFieldVm">
                                                            <TextBox HorizontalAlignment="Stretch" MinWidth="0"
                                                                     Text="{Binding Text, Mode=TwoWay}" />
                                                        </DataTemplate>
                                                        <DataTemplate x:DataType="vm:RangeFieldVm">
                                                            <!-- Slider column is Auto + capped width: avoid * eating full config width -->
                                                            <Grid ColumnDefinitions="Auto,*,80" ColumnSpacing="12" VerticalAlignment="Center">
                                                                <Slider Minimum="{Binding Min}" Maximum="{Binding Max}"
                                                                        Value="{Binding Value, Mode=TwoWay}"
                                                                        IsSnapToTickEnabled="{Binding IsSnapToTickEnabled}"
                                                                        TickFrequency="{Binding TickFrequency}"
                                                                        MinWidth="120" MaxWidth="280"
                                                                        HorizontalAlignment="Left" />
                                                                <TextBox Grid.Column="2" Width="80" HorizontalAlignment="Right"
                                                                         Text="{Binding ValueText, Mode=TwoWay}" />
                                                            </Grid>
                                                        </DataTemplate>
                                                        <DataTemplate x:DataType="vm:NumberFieldVm">
                                                            <!-- Spinbox-like number input:
                                                                 TextBox for value + two vertical arrow buttons beside it. -->
                                                            <Grid ColumnDefinitions="Auto,28" ColumnSpacing="0" VerticalAlignment="Center">
                                                                <TextBox Grid.Column="0" MinWidth="0"
                                                                         Width="{Binding SuggestedTextBoxWidth}"
                                                                         FontFamily="{DynamicResource MonospaceFontFamily}"
                                                                         Text="{Binding ValueText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                         HorizontalAlignment="Left" />
                                                                <Grid Grid.Column="1" RowDefinitions="*,*">
                                                                    <Button Grid.Row="0" Classes="secondary"
                                                                            Content="▲"
                                                                            Command="{Binding IncreaseCommand}"
                                                                            MinWidth="28" MinHeight="0"
                                                                            Padding="0"
                                                                            CornerRadius="0"
                                                                            BorderThickness="1,1,1,0"
                                                                            HorizontalContentAlignment="Center"
                                                                            VerticalContentAlignment="Center" />
                                                                    <Button Grid.Row="1" Classes="secondary"
                                                                            Content="▼"
                                                                            Command="{Binding DecreaseCommand}"
                                                                            MinWidth="28" MinHeight="0"
                                                                            Padding="0"
                                                                            CornerRadius="0"
                                                                            BorderThickness="1,0,1,1"
                                                                            HorizontalContentAlignment="Center"
                                                                            VerticalContentAlignment="Center" />
                                                                </Grid>
                                                            </Grid>
                                                        </DataTemplate>
                                                        <DataTemplate x:DataType="vm:CheckboxFieldVm">
                                                            <CheckBox IsChecked="{Binding IsChecked, Mode=TwoWay}" />
                                                        </DataTemplate>
                                                        <DataTemplate x:DataType="vm:SelectFieldVm">
                                                            <ComboBox MinWidth="0" HorizontalAlignment="Stretch"
                                                                      ItemsSource="{Binding Options}"
                                                                      SelectedItem="{Binding Selected}" />
                                                        </DataTemplate>
                                                        <DataTemplate x:DataType="vm:PathFieldVm">
                                                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                                                                <TextBox HorizontalAlignment="Stretch" MinWidth="0"
                                                                         Text="{Binding Path, Mode=TwoWay}" />
                                                                <Button Grid.Column="1" MinWidth="88" Classes="secondary"
                                                                        Content="{Binding $parent[Window].DataContext.OutputBrowseLabel}"
                                                                        Command="{Binding $parent[Window].DataContext.BrowseConfigPathCommand}"
                                                                        CommandParameter="{Binding}" />
                                                            </Grid>
                                                        </DataTemplate>
                                                    </ContentControl.DataTemplates>
                                                </ContentControl>
                                                <TextBlock Classes="help-text" TextWrapping="Wrap" Text="{Binding Help}" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <!-- 输出 -->
                    <StackPanel Spacing="10">
                        <TextBlock FontWeight="SemiBold" FontSize="16" Text="{Binding OutputHeader}"
                                   Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}" />
                        <Border Classes="card" HorizontalAlignment="Stretch">
                            <StackPanel Spacing="14">
                                <StackPanel Spacing="12" IsEnabled="{Binding CanEdit}">
                                    <CheckBox Content="{Binding UseInputDirLabel}"
                                              IsChecked="{Binding UseInputDirAsOutput}" />
                                    <TextBlock Text="{Binding OutputDirLabel}" IsVisible="{Binding !UseInputDirAsOutput}" />
                                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10"
                                          IsVisible="{Binding !UseInputDirAsOutput}">
                                        <TextBox Text="{Binding OutputDir, Mode=TwoWay}"
                                                 IsEnabled="{Binding !UseInputDirAsOutput}" />
                                        <Button Grid.Column="1" MinWidth="100"
                                                Content="{Binding OutputBrowseLabel}"
                                                IsEnabled="{Binding !UseInputDirAsOutput}"
                                                Command="{Binding BrowseOutputDirCommand}" />
                                    </Grid>
                                    <TextBlock VerticalAlignment="Center" Text="{Binding NamingTemplateLabel}" />
                                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                        <StackPanel Grid.Column="0" Spacing="8">
                                            <!-- Selected tokens -->
                                            <Border CornerRadius="10"
                                                    BorderThickness="1"
                                                    BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                                                    Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"
                                                    Padding="10,8">
                                                <ItemsControl ItemsSource="{Binding NamingTemplateSelectedTags}">
                                                    <ItemsControl.ItemsPanel>
                                                        <ItemsPanelTemplate>
                                                            <WrapPanel />
                                                        </ItemsPanelTemplate>
                                                    </ItemsControl.ItemsPanel>
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate x:DataType="vm:NamingTemplateTokenVm">
                                                            <Border Classes="tag-chip"
                                                                    input:DragDrop.AllowDrop="True"
                                                                    input:DragDrop.DragOver="OnNamingTemplateTagDragOver"
                                                                    input:DragDrop.Drop="OnNamingTemplateTagDrop"
                                                                    PointerPressed="OnNamingTemplateTagPointerPressed">
                                                                <StackPanel Orientation="Horizontal" Spacing="6"
                                                                            VerticalAlignment="Center"
                                                                            Margin="0">
                                                                    <TextBlock Text="{Binding DisplayText}"
                                                                               Opacity="0.95"
                                                                               VerticalAlignment="Center"
                                                                               TextTrimming="CharacterEllipsis" />
                                                                </StackPanel>
                                                            </Border>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </Border>

                                            <!-- Action chips -->
                                            <WrapPanel>
                                                <ToggleButton Content="{Binding NamingTemplateBaseCandidateText}"
                                                               Classes="tag-chip"
                                                               MinHeight="30"
                                                               Padding="12,6"
                                                               IsChecked="{Binding HasNamingTemplateBaseToken, Mode=OneWay}"
                                                               Command="{Binding AddNamingTemplateTokenCommand}"
                                                               CommandParameter="{Binding NamingTemplateBaseCandidateValue}" />
                                                <ToggleButton Content="{Binding NamingTemplateIndexCandidateText}"
                                                               Classes="tag-chip"
                                                               MinHeight="30"
                                                               Padding="12,6"
                                                               IsChecked="{Binding HasNamingTemplateIndexToken, Mode=OneWay}"
                                                               Command="{Binding AddNamingTemplateTokenCommand}"
                                                               CommandParameter="{Binding NamingTemplateIndexCandidateValue}" />
                                                <ToggleButton Content="{Binding NamingTemplateTimeDateCandidateText}"
                                                               Classes="tag-chip"
                                                               MinHeight="30"
                                                               Padding="12,6"
                                                               IsChecked="{Binding HasNamingTemplateTimeYmdToken, Mode=OneWay}"
                                                               Command="{Binding AddNamingTemplateTokenCommand}"
                                                               CommandParameter="{Binding NamingTemplateTimeDateCandidateValue}" />
                                                <ToggleButton Content="{Binding NamingTemplateTimeHmsCandidateText}"
                                                               Classes="tag-chip"
                                                               MinHeight="30"
                                                               Padding="12,6"
                                                               IsChecked="{Binding HasNamingTemplateTimeHmsToken, Mode=OneWay}"
                                                               Command="{Binding AddNamingTemplateTokenCommand}"
                                                               CommandParameter="{Binding NamingTemplateTimeHmsCandidateValue}" />
                                                <ToggleButton Content="{Binding NamingTemplateCustom1CandidateText}"
                                                               Classes="tag-chip"
                                                               MinHeight="30"
                                                               Padding="12,6"
                                                               IsChecked="{Binding HasNamingTemplateCustom1Token, Mode=OneWay}"
                                                               Command="{Binding AddNamingTemplateTokenCommand}"
                                                               CommandParameter="{Binding NamingTemplateCustom1CandidateValue}" />
                                                <ToggleButton Content="{Binding NamingTemplateCustom2CandidateText}"
                                                               Classes="tag-chip"
                                                               MinHeight="30"
                                                               Padding="12,6"
                                                               IsChecked="{Binding HasNamingTemplateCustom2Token, Mode=OneWay}"
                                                               Command="{Binding AddNamingTemplateTokenCommand}"
                                                               CommandParameter="{Binding NamingTemplateCustom2CandidateValue}" />
                                                <ToggleButton Content="{Binding NamingTemplateCustom3CandidateText}"
                                                               Classes="tag-chip"
                                                               MinHeight="30"
                                                               Padding="12,6"
                                                               IsChecked="{Binding HasNamingTemplateCustom3Token, Mode=OneWay}"
                                                               Command="{Binding AddNamingTemplateTokenCommand}"
                                                               CommandParameter="{Binding NamingTemplateCustom3CandidateValue}" />
                                            </WrapPanel>
                                            <!-- Custom label name inputs (i18n via VM) -->
                                            <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,8,0,0">
                                                <TextBlock VerticalAlignment="Center" Opacity="0.7" Text="{Binding NamingTemplateCustomRowLabel}" />
                                                <TextBox Width="80"
                                                         Text="{Binding CustomToken1Text, Mode=TwoWay}"
                                                         Watermark="{Binding CustomToken1Watermark}"
                                                         FontSize="12" />
                                                <TextBox Width="80"
                                                         Text="{Binding CustomToken2Text, Mode=TwoWay}"
                                                         Watermark="{Binding CustomToken2Watermark}"
                                                         FontSize="12" />
                                                <TextBox Width="80"
                                                         Text="{Binding CustomToken3Text, Mode=TwoWay}"
                                                         Watermark="{Binding CustomToken3Watermark}"
                                                         FontSize="12" />
                                            </StackPanel>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6"
                                                    VerticalAlignment="Center"
                                                    IsVisible="{Binding HasNamingTemplateExtSuffix}">
                                            <TextBlock Opacity="0.7" Text="{Binding NamingTemplateExtSuffixPrefix}" />
                                            <TextBlock FontFamily="{DynamicResource MonospaceFontFamily}"
                                                       Opacity="0.85"
                                                       Text="{Binding NamingTemplateExtSuffix}" />
                                        </StackPanel>
                                    </Grid>
                                    <TextBlock Classes="help-text" TextWrapping="Wrap"
                                               Text="{Binding NamingTemplateHelp}" />
                                    <CheckBox Content="{Binding KeepTempLabel}" IsChecked="{Binding KeepTemp}"
                                              IsEnabled="{Binding CanEdit}" />
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </StackPanel>

            </ScrollViewer>

            <!-- 左/右分区视觉提示 -->
            <Border Grid.Column="1" Background="{DynamicResource SystemControlForegroundBaseLowBrush}"
                    Width="1" Opacity="0.35" />

            <!-- 右侧：处理控制（按钮纵向 + 暂停/终止并排） -->
            <!-- 右侧单独滚动：避免整页滚动，同时当内容过长时不会遮住底部控件 -->
            <ScrollViewer Grid.Column="2"
                              VerticalScrollBarVisibility="Hidden"
                              HorizontalScrollBarVisibility="Disabled"
                              Padding="0,0,10,0"
                              Margin="12,0,0,0">
                <StackPanel Spacing="10" MinWidth="360">
                        <TextBlock FontWeight="SemiBold" FontSize="16" Text="{Binding ProcessHeader}"
                                   Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}" />
                        <Border Classes="card">
                            <StackPanel Spacing="16">
                            <TextBlock Text="{Binding ProcessPlaceholder}" TextWrapping="Wrap" Opacity="0.9" />
                            <StackPanel Spacing="8">
                                <ProgressBar Minimum="0" Maximum="100" Height="8"
                                             Value="{Binding Progress}" HorizontalAlignment="Stretch" />
                                <TextBlock Opacity="0.8" FontSize="13" Text="{Binding ProgressText}"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                            <TextBlock Opacity="0.85" FontSize="13" Text="{Binding BatchText}" TextWrapping="Wrap" />
                            <!-- 操作区：开始独占一行；暂停 / 终止并排等分 -->
                            <StackPanel Spacing="10">
                                <Button Classes="primary" Content="{Binding StartLabel}"
                                        Command="{Binding StartCommand}" IsEnabled="{Binding CanStart}"
                                        HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                                        MinHeight="40" />
                                <Grid ColumnDefinitions="*,12,*">
                                    <Button Grid.Column="0" Classes="secondary" Content="{Binding PauseLabel}"
                                            ToolTip.Tip="{Binding PauseTooltipLabel}"
                                            Command="{Binding PauseCommand}" IsEnabled="{Binding IsBusy}"
                                            HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                                            MinHeight="40" />
                                    <Button Grid.Column="2" Classes="secondary" Content="{Binding StopLabel}"
                                            Command="{Binding StopCommand}" IsEnabled="{Binding IsBusy}"
                                            HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                                            MinHeight="40" />
                                </Grid>
                            </StackPanel>
                            <Separator Background="{DynamicResource SystemControlForegroundBaseLowBrush}" Height="1"
                                       Opacity="0.35" />
                            <CheckBox Content="{Binding EnableParallelLabel}"
                                      IsChecked="{Binding EnableParallelProcessing}"
                                      IsEnabled="{Binding CanEdit}" />
                            <StackPanel Spacing="8" IsVisible="{Binding EnableParallelProcessing}"
                                        IsEnabled="{Binding CanEdit}">
                                <TextBlock Opacity="0.8" Text="{Binding ParallelismLabel}" TextWrapping="Wrap" />
                                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12" VerticalAlignment="Center">
                                    <Slider Grid.Column="0" Minimum="1" Maximum="8" TickFrequency="1"
                                            IsSnapToTickEnabled="True"
                                            HorizontalAlignment="Stretch"
                                            Value="{Binding Parallelism, Mode=TwoWay}" />
                                    <TextBlock Grid.Column="1" MinWidth="28" FontWeight="SemiBold"
                                               VerticalAlignment="Center" Text="{Binding Parallelism}" />
                                </Grid>
                            </StackPanel>
                            <TextBlock FontWeight="SemiBold" Opacity="0.85" Text="{Binding ProcessLogSectionLabel}" />
                            <TextBox x:Name="ProcessLogBox" AcceptsReturn="True" IsReadOnly="True"
                                     Classes="log-box" Height="180" MinHeight="120"
                                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                     TextWrapping="Wrap"
                                     Text="{Binding ProcessLog}" />

                            <Separator Background="{DynamicResource SystemControlForegroundBaseLowBrush}" Height="1"
                                       Opacity="0.35" />
                            <TextBlock FontWeight="SemiBold" Opacity="0.85" Text="{Binding OutputHeader}" />
                            <TextBox Classes="log-box" IsReadOnly="True" AcceptsReturn="True"
                                     Text="{Binding OutputText}" Height="160"
                                     TextWrapping="Wrap"
                                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                                     ScrollViewer.AllowAutoHide="False"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled" />
                            </StackPanel>
                        </Border>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </DockPanel>
</Window>
